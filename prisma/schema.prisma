generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String              @id @default(uuid())
  email                    String              @unique
  name                     String
  avatarUrl                String?             @map("avatar_url")
  role                     UserRole            @default(member)
  status                   UserStatus          @default(active)
  joinedAt                 DateTime            @map("joined_at")
  deactivatedAt            DateTime?           @map("deactivated_at")
  phoneNumber              String?             @map("phone_number")
  phoneNumber2             String?             @map("phone_number_2")
  bkashNumber              String?             @map("bkash_number")
  bankName                 String?             @map("bank_name")
  bankAccountNumber        String?             @map("bank_account_number")
  emergencyContactName     String?             @map("emergency_contact_name")
  emergencyContactPhone    String?             @map("emergency_contact_phone")
  emergencyContactRelation String?             @map("emergency_contact_relation")
  nickname                 String?
  bazarExpenses            BazarExpense[]
  assignedTrips1           BazarTrip[]         @relation("BazarTripAssignee1")
  assignedTrips2           BazarTrip[]         @relation("BazarTripAssignee2")
  triggeredTrips           BazarTrip[]         @relation("BazarTripTriggeredBy")
  bulkAllocations          BulkAllocation[]
  bulkCyclesFinished       BulkCycle[]         @relation("BulkCycleFinishedBy")
  bulkCyclesPurchased      BulkCycle[]         @relation("BulkCyclePurchasedBy")
  fridgePayments           FridgePayment[]
  maidCharges              MaidCharge[]
  maidPayments             MaidPayment[]
  reviewedEditReqs         MealEditRequest[]   @relation("MealEditRequestReviewer")
  mealEditRequests         MealEditRequest[]   @relation("MealEditRequestUser")
  mealPattern              MealPattern?
  mealRecords              MealRecord[]
  reviewedMemberships      MembershipRequest[] @relation("MembershipRequestReviewer")
  approvedRequest          MembershipRequest?  @relation("MembershipRequestUser")
  settlementsFrom          MonthlySettlement[] @relation("SettlementFrom")
  settlementsTo            MonthlySettlement[] @relation("SettlementTo")
  systemConfigUpdates      SystemConfig[]
  pushSubscriptions        PushSubscription[]
  notificationDeliveries   NotificationDelivery[]

  @@map("User")
}

model FridgeBill {
  id              String          @id @default(uuid())
  month           DateTime        @unique @db.Date
  totalAmount     Decimal         @map("total_amount") @db.Decimal(12, 2)
  perMemberAmount Decimal         @map("per_member_amount") @db.Decimal(12, 2)
  memberCount     Int             @map("member_count")
  postedAt        DateTime        @map("posted_at")
  postedById      String          @map("posted_by")
  previousReading Decimal         @map("previous_reading") @db.Decimal(10, 2)
  currentReading  Decimal         @map("current_reading") @db.Decimal(10, 2)
  unitPrice       Decimal         @map("unit_price") @db.Decimal(10, 4)
  payments        FridgePayment[]

  @@map("FridgeBill")
}

model FridgePayment {
  id       String     @id @default(uuid())
  billId   String     @map("bill_id")
  paidById String     @map("paid_by")
  amount   Decimal    @db.Decimal(12, 2)
  paidAt   DateTime   @map("paid_at")
  bill     FridgeBill @relation(fields: [billId], references: [id])
  paidBy   User       @relation(fields: [paidById], references: [id])

  @@map("FridgePayment")
}

model MembershipRequest {
  id           String                  @id @default(uuid())
  email        String
  name         String
  avatarUrl    String?                 @map("avatar_url")
  status       MembershipRequestStatus @default(pending)
  requestedAt  DateTime                @map("requested_at")
  reviewedAt   DateTime?               @map("reviewed_at")
  reviewedById String?                 @map("reviewed_by")
  userId       String?                 @unique @map("user_id")
  reviewedBy   User?                   @relation("MembershipRequestReviewer", fields: [reviewedById], references: [id])
  user         User?                   @relation("MembershipRequestUser", fields: [userId], references: [id])

  @@map("MembershipRequest")
}

model MealPattern {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  monday    Int      @default(0)
  tuesday   Int      @default(0)
  wednesday Int      @default(0)
  thursday  Int      @default(0)
  friday    Int      @default(0)
  saturday  Int      @default(0)
  sunday    Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("MealPattern")
}

model MealRecord {
  id           String            @id @default(uuid())
  userId       String            @map("user_id")
  date         DateTime          @db.Date
  mealCount    Int               @default(0) @map("meal_count")
  isLocked     Boolean           @default(false) @map("is_locked")
  editRequests MealEditRequest[]
  user         User              @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("MealRecord")
}

model MealEditRequest {
  id           String                @id @default(uuid())
  userId       String                @map("user_id")
  mealRecordId String                @map("meal_record_id")
  status       MealEditRequestStatus @default(pending)
  requestedAt  DateTime              @map("requested_at")
  reviewedById String?               @map("reviewed_by")
  reviewedAt   DateTime?             @map("reviewed_at")
  mealRecord   MealRecord            @relation(fields: [mealRecordId], references: [id])
  reviewedBy   User?                 @relation("MealEditRequestReviewer", fields: [reviewedById], references: [id])
  user         User                  @relation("MealEditRequestUser", fields: [userId], references: [id])

  @@map("MealEditRequest")
}

model BazarTrip {
  id            String          @id @default(uuid())
  triggeredById String          @map("triggered_by")
  assignee1Id   String?         @map("assignee_1")
  assignee2Id   String?         @map("assignee_2")
  shoppingNotes String?         @map("shopping_notes")
  status        BazarTripStatus @default(open)
  triggeredAt   DateTime        @map("triggered_at")
  completedAt   DateTime?       @map("completed_at")
  expenses      BazarExpense[]
  assignee1     User?           @relation("BazarTripAssignee1", fields: [assignee1Id], references: [id])
  assignee2     User?           @relation("BazarTripAssignee2", fields: [assignee2Id], references: [id])
  triggeredBy   User            @relation("BazarTripTriggeredBy", fields: [triggeredById], references: [id])
  systemConfig  SystemConfig[]

  @@map("BazarTrip")
}

model BazarExpense {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tripId      String    @map("trip_id")
  amount      Decimal   @db.Decimal(12, 2)
  tripWeight  Decimal   @default(1.0) @map("trip_weight") @db.Decimal(3, 2)
  note        String?
  date        DateTime  @db.Date
  submittedAt DateTime  @map("submitted_at")
  trip        BazarTrip @relation(fields: [tripId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("BazarExpense")
}

model BulkItem {
  id        String      @id @default(uuid())
  name      String      @unique
  unit      String?
  createdAt DateTime    @map("created_at")
  cycles    BulkCycle[]

  @@map("BulkItem")
}

model BulkCycle {
  id            String           @id @default(uuid())
  bulkItemId    String           @map("bulk_item_id")
  purchasedById String           @map("purchased_by")
  cost          Decimal          @db.Decimal(12, 2)
  purchaseDate  DateTime         @map("purchase_date") @db.Date
  status        BulkCycleStatus  @default(active)
  startedAt     DateTime         @map("started_at")
  finishedAt    DateTime?        @map("finished_at")
  finishedById  String?          @map("finished_by")
  allocations   BulkAllocation[]
  bulkItem      BulkItem         @relation(fields: [bulkItemId], references: [id])
  finishedBy    User?            @relation("BulkCycleFinishedBy", fields: [finishedById], references: [id])
  purchasedBy   User             @relation("BulkCyclePurchasedBy", fields: [purchasedById], references: [id])

  @@map("BulkCycle")
}

model BulkAllocation {
  id               String    @id @default(uuid())
  cycleId          String    @map("cycle_id")
  userId           String    @map("user_id")
  mealsDuringCycle Int       @map("meals_during_cycle")
  amount           Decimal   @db.Decimal(12, 2)
  allocatedAt      DateTime  @map("allocated_at")
  cycle            BulkCycle @relation(fields: [cycleId], references: [id])
  user             User      @relation(fields: [userId], references: [id])

  @@unique([userId, cycleId])
  @@map("BulkAllocation")
}

model MaidCharge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Decimal  @db.Decimal(12, 2)
  month     DateTime @db.Date
  appliedAt DateTime @map("applied_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@map("MaidCharge")
}

model MaidPayment {
  id       String   @id @default(uuid())
  paidById String   @map("paid_by")
  amount   Decimal  @db.Decimal(12, 2)
  month    DateTime @db.Date
  note     String?
  paidAt   DateTime @map("paid_at")
  paidBy   User     @relation(fields: [paidById], references: [id])

  @@map("MaidPayment")
}

model MonthlySettlement {
  id         String   @id @default(uuid())
  month      DateTime @db.Date
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  amount     Decimal  @db.Decimal(12, 2)
  settledAt  DateTime @map("settled_at")
  fromUser   User     @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("SettlementTo", fields: [toUserId], references: [id])

  @@map("MonthlySettlement")
}

model SystemConfig {
  id                   String     @id @default(uuid())
  mealDeadline         String     @map("meal_deadline")
  maidChargeDefault    Decimal    @map("maid_charge_default") @db.Decimal(12, 2)
  activeTripId         String?    @map("active_trip_id")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  updatedById          String?    @map("updated_by")
  electricityUnitPrice Decimal    @default(8) @map("electricity_unit_price") @db.Decimal(10, 4)
  activeTrip           BazarTrip? @relation(fields: [activeTripId], references: [id])
  updatedBy            User?      @relation(fields: [updatedById], references: [id])

  @@map("SystemConfig")
}

model PushSubscription {
  id           String                 @id @default(uuid())
  userId       String                 @map("user_id")
  endpoint     String                 @unique
  p256dh       String
  auth         String
  userAgent    String?                @map("user_agent")
  isActive     Boolean                @default(true) @map("is_active")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  lastFailedAt DateTime?              @map("last_failed_at")
  user         User                   @relation(fields: [userId], references: [id])
  deliveries   NotificationDelivery[]

  @@index([userId, isActive])
  @@map("PushSubscription")
}

model NotificationDelivery {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  subscriptionId String?           @map("subscription_id")
  reminderDate   DateTime          @map("reminder_date") @db.Date
  type           MealReminderType
  sentAt         DateTime          @map("sent_at")
  user           User              @relation(fields: [userId], references: [id])
  subscription   PushSubscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([userId, reminderDate, type])
  @@index([reminderDate, type])
  @@map("NotificationDelivery")
}

enum UserRole {
  member
  admin
}

enum UserStatus {
  active
  deactivated
}

enum MembershipRequestStatus {
  pending
  approved
  rejected
}

enum BazarTripStatus {
  open
  completed
}

enum BulkCycleStatus {
  active
  finished
}

enum MealEditRequestStatus {
  pending
  approved
  rejected
  expired
}

enum MealReminderType {
  previous_night
  deadline_morning
}
